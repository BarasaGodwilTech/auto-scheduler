# ClipFlow Pro — API Keys
# These are configured in-app via Settings → API Keys
# Keys are stored encrypted in IndexedDB, never sent to a server

# ─── TikTok ───────────────────────────────────────────────────────────────────
# Register at: https://developers.tiktok.com/
# App type: Web, Scopes: user.info.basic, video.upload, video.publish
TIKTOK_CLIENT_KEY=aw_xxxxxxxxxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URI to add in TikTok developer console:
# https://your-domain.com/auth/callback.html

# ─── Facebook / Instagram ─────────────────────────────────────────────────────
# Register at: https://developers.facebook.com/
# Products to add: Facebook Login, Instagram Graph API
# Permissions: instagram_basic, instagram_content_publish, pages_read_engagement
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URI to add in Facebook app settings:
# https://your-domain.com/auth/callback.html

# ─── Google / YouTube ─────────────────────────────────────────────────────────
# Register at: https://console.cloud.google.com/
# Enable: YouTube Data API v3
# OAuth 2.0 Scopes: youtube.upload, youtube.readonly
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Redirect URI to add in Google OAuth consent screen:
# https://your-domain.com/auth/callback.html

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. For local dev, use https://localhost:PORT (HTTPS required for OAuth)
# 2. Use Live Server + a local SSL cert, or deploy to Netlify/Vercel
# 3. FFmpeg.wasm requires COOP/COEP headers — provided by the service worker
# 4. Instagram requires a Facebook Business account with an Instagram Professional account linked
